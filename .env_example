# Obsidian vault с заметками
VAULT_PATH=/absolute/path/to/obsidian/vault

# Chunking для индексации
# CHUNK_SIZE от 500 до 1500
# CHUNK_OVERLAP от 100 до 300
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# Ollama embeddings endpoint
OLLAMA_URL=http://localhost:11434/api/embeddings
MODEL=nomic-embed-text

# ChromaDB storage
CHROMA_PATH=./chroma_db

EXCLUDE_DIRS=.obsidian,templates,daily,archive,ai_obsidian,AI_Search